# Copy to .env and fill in. .env is gitignored — never commit real secrets.

# Entra ID app registration (app-only / client credentials).
# Reuse the SAME values as the OnTrack Room Booking app (ontrack-api).
ENTRA_TENANT_ID=
ENTRA_CLIENT_ID=
ENTRA_CLIENT_SECRET=

# Flask session signing key (use a long random value in production).
SECRET_KEY=dev-secret-change-me
