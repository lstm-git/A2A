# Copy to .env and fill in. .env is gitignored — never commit real secrets.

# Entra ID app registration (app-only / client credentials).
# Reuse the SAME values as the OnTrack Room Booking app (ontrack-api).
ENTRA_TENANT_ID=
ENTRA_CLIENT_ID=
ENTRA_CLIENT_SECRET=

# Flask session signing key (use a long random value in production).
SECRET_KEY=dev-secret-change-me

# --- Approval email notifications (Phase 3) ---
# Dev-safe: leave A2A_EMAIL_ENABLED unset/0 to LOG emails instead of sending.
# Set to 1 on the VM to actually send via the LSTM relay (same relay Catering /
# Room Booking use). No SMTP auth — internal relay.
A2A_EMAIL_ENABLED=0
A2A_SMTP_HOST=smtprelay.lstmed.ac.uk
A2A_SMTP_PORT=25
A2A_FROM_EMAIL=a2a-smtp@lstmed.ac.uk
# Absolute base URL for approve links in emails (prefix included).
A2A_BASE_URL=https://trackon.lstmed.ac.uk/A2A
# Placeholder mailbox for all fixed role-holders until real addresses are wired.
A2A_PLACEHOLDER_EMAIL=daniel.williams@lstmed.ac.uk
